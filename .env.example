# Transmutary 凭据模板 — 复制为 .env 填写（.env 不入库，见 .gitignore）。
# 凭据只从环境读取，不入库、不入镜像（R21/KTD4）。

# GitHub 只读 token（采集 release/issue/依赖）
TRANSMUTARY_GITHUB_TOKEN=

# LLM provider（任意 LiteLLM 支持）；base_url 可选（OpenAI/Anthropic-compatible 端点）
TRANSMUTARY_LLM_API_KEY=
TRANSMUTARY_LLM_BASE_URL=

# 邮件投递（SMTP）；RSS-only 部署可留空（仅 RSS 投递）
TRANSMUTARY_SMTP_USER=
TRANSMUTARY_SMTP_PASSWORD=

# 私有 RSS feed 鉴权 token
TRANSMUTARY_RSS_TOKEN=

# 可选：L3 日预算上限（USD/天），默认 5.0
# TRANSMUTARY_L3_DAILY_BUDGET_USD=5.0
